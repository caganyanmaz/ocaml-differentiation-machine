module type Num_sig = sig
        type t
        val zero : t
        val one : t
        val minus_one : t

        val add : t -> t -> t
        val sub : t -> t -> t
        val mul : t -> t -> t
        val neg : t -> t
        val compare : t -> t -> int
        val equal : t -> t -> bool
        val abs : t -> t
end

module type Diff_num_sig = sig
        include Num_sig
        type nt
        val const : nt -> t
        val id : nt -> t
        val zip_with : (nt -> nt -> nt) -> t -> t -> t
        val map : (nt -> nt) -> t -> t
        val diff : t -> t
end


module Diff_num (N : Num_sig) : Diff_num_sig  = struct
        type t  = D of N.t * t Lazy.t
        type nt = N.t

        let rec zero      = D (N.zero, lazy zero)
        let one       = D (N.one, lazy zero)
        let minus_one = D (N.minus_one, lazy zero)

        let const x = D (x, lazy zero)
        let rec id x = D (x, lazy (id x))

        let rec zip_with f xs ys =
                match (xs, ys) with
                | (D (x, xs), D (y, ys)) -> D (f x y, lazy (zip_with f (Lazy.force xs) (Lazy.force ys)))
        let rec map f = function
                | D (x, xs) -> D (f x, lazy (map f (Lazy.force xs)))

        let add = zip_with N.add
        let sub = zip_with N.sub
        let rec mul xs ys =
                match (xs, ys) with
                | (D (x, xs), D (y, ys)) -> D (N.mul x y, lazy (add (mul (const x) (Lazy.force ys)) (mul (const y) (Lazy.force ys))))
        let neg = map N.neg

        let compare xs ys = 
                match (xs, ys) with
                | (D (x, xs), D (y, ys)) -> N.compare x y

        let equal xs ys = (compare xs ys) = 0

        let abs xs =
                let signum x =
                        let res = N.compare x N.zero in
                        if res = 0 then zero else (if res < 0 then minus_one else one) in
                match xs with
                | D (x, xs) -> 
                        let sign = signum x in
                        if (equal zero sign) then raise (Invalid_argument "hi")
                        else D (N.abs x, lazy (mul sign (Lazy.force xs)))

        let diff = function
                | D (_, xs) -> Lazy.force xs

end

module type Num_to_float_sig = sig
        type t
        val div : t -> t -> t
end

module type Float_sig = sig
        include Num_sig
        include Num_to_float_sig with type t := t
end

module type Diff_float_sig = sig
        include Diff_num_sig
        include Num_to_float_sig with type t := t
end

module Diff_float  (Float : Float_sig) : Diff_float_sig = struct
        include Diff_num (Float)
        let rec div a b =
                match (a, b) with
                | (D (x, xs), D (y, ys)) ->
                        let value     = Float.div x y in
                        let numerator = lazy (sub (mul (Lazy.force xs) (D (y, ys)))  (mul (D (x, xs)) (Lazy.force ys)))
                        in
                        let denominator = lazy (mul (D (y, ys)) (D (y, ys))) in
                        let diff = lazy (div (Lazy.force numerator) (Lazy.force denominator)) in
                        D (value, diff)
end 

module My_int : Num_sig = struct include Int end

module My_float : Float_sig = struct include Float end

module My_diff_int : Diff_num_sig = Diff_num (Int)


let () = print_endline "Hello, World!"
